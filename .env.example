# Configuration de l'application Kengni Finance

# Clé secrète Flask (générez-en une unique en production)
SECRET_KEY=votre_cle_secrete_super_securisee_ici

# Chemin de la base de données
DATABASE_PATH=kengni_finance.db

# Port de l'application (défaut: 5000)
PORT=5000

# Mode debug (False en production)
FLASK_DEBUG=False

# Environnement (development, production)
FLASK_ENV=production
